# Copy to /etc/uptime-kuma-auto-update.env and edit for your server.
# Keep this file private if you add database credentials.

PROJECT_DIR=/www/server/uptime-kuma
KUMA_SERVICE=uptime-kuma
KUMA_IMAGE=louislam/uptime-kuma:2

BACKUP_ROOT=/www/server/uptime-kuma/backups/auto-update
BACKUP_RETENTION_DAYS=30

# Set to 1 only when your Uptime Kuma data is a local SQLite ./data directory.
# For MariaDB / MySQL deployments, prefer BACKUP_SQL instead.
BACKUP_DATA_DIR=0
DATA_DIR=data

# Optional database dump. Do not commit real credentials.
BACKUP_SQL=0
DB_SERVICE=db
# When BACKUP_SQL=1 and DB_DUMP_COMMAND is empty, the updater runs mariadb-dump
# inside DB_SERVICE and reads MARIADB_USER, MARIADB_PASSWORD, and
# MARIADB_DATABASE from that container.
# DB_DUMP_COMMAND='docker compose exec -T db sh -lc '\''mariadb-dump -u"$MARIADB_USER" -p"$MARIADB_PASSWORD" "$MARIADB_DATABASE"'\'''

STARTUP_WAIT_SECONDS=15
LOG_TAIL=200
AUTO_ROLLBACK=1

# Optional public page check after the container starts.
# HEALTHCHECK_URL=https://status.example.com/

# Optional generic JSON webhook. The script posts {"status":"...","message":"..."}.
# WEBHOOK_URL=
